# ─────────────────────────────────────────────────────────────────────────────
# Market Analytics System — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider Selection ────────────────────────────────────────────────────────
# Options: "mock" (default, no credentials required) | "icici" (live Breeze API)
# Both MARKET_DATA_PROVIDER and DATA_PROVIDER are accepted.
MARKET_DATA_PROVIDER=mock
# DATA_PROVIDER=mock  ← alternative alias, same effect

# ── ICICI Direct / Breeze Connect ────────────────────────────────────────────
# Obtain from https://api.icicidirect.com
# Both ICICI_APP_KEY/ICICI_SECRET_KEY and ICICI_API_KEY/ICICI_API_SECRET are accepted.
# Requires static IP whitelisting — see docs/ICICI_SETUP.md.
ICICI_APP_KEY=
# ICICI_API_KEY=     ← alternative alias for ICICI_APP_KEY

ICICI_SECRET_KEY=
# ICICI_API_SECRET=  ← alternative alias for ICICI_SECRET_KEY

# Session token is generated daily via the ICICI login URL.
# Run: python scripts/refresh_session.py
ICICI_SESSION_TOKEN=

# Optional: your ICICI Direct client code / user ID
ICICI_CLIENT_CODE=

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path (relative to project root)
DATABASE_URL=sqlite:///data/market_data.db

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_HISTORICAL=900
CACHE_TTL_LIVE=15

# ── Scheduler ─────────────────────────────────────────────────────────────────
LIVE_REFRESH_INTERVAL_SECONDS=5
METRICS_REFRESH_INTERVAL_SECONDS=900
HISTORICAL_REFRESH_HOUR_IST=17

# ── Universe ─────────────────────────────────────────────────────────────────
UNIVERSE_FILE=data/universe/nifty500.csv
# Set to 0 for full universe; use a small number (e.g. 20) for quick testing
UNIVERSE_SIZE_LIMIT=0

# ── Analytics ────────────────────────────────────────────────────────────────
TRADING_DAYS_PER_YEAR=252
# India risk-free rate (approximate 91-day T-bill rate)
RISK_FREE_RATE=0.065

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=logs/application.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Market Hours (IST, 24h) ───────────────────────────────────────────────────
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
